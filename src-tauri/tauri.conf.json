{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw 安装器",
  "version": "0.1.0",
  "identifier": "com.openclaw.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw 安装器",
        "width": 860,
        "height": 640,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../scripts": "scripts"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": null
    },
    "macOS": {
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "_updater_disabled_for_test": {
      "note": "正式发布前执行 cargo tauri signer generate 生成真实 pubkey 后再启用",
      "pubkey": "PLACEHOLDER_PUBKEY",
      "endpoints": [
        "https://github.com/openclaw/openclaw-anzhuang/releases/latest/download/latest.json"
      ]
    }
  }
}
